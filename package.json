{
  "name": "janix",
  "version": "0.3.0",
  "description": "Isolated Docker + Nix dev environments per git branch",
  "type": "module",
  "bin": {
    "janix": "./dist/cli.js"
  },
  "files": [
    "dist",
    "support"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "janix": "node dist/cli.js",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "check": "npm run format && npm run lint && npm run typecheck",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "8.4.1",
    "@inquirer/search": "4.1.7",
    "@sindresorhus/slugify": "3.0.0",
    "commander": "14.0.3",
    "dotenv": "17.4.1"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.5.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "6.0.2"
  }
}
